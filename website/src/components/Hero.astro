---
const title = "Ship software,<br/>not scripts";
const tagline = "A single CLI that builds, tests, signs, and publishes across every framework. Replace your patchwork of fastlane, shell scripts, and CI hacks.";
const actions = [
	{ text: "Get started", link: "/canaveral/getting-started/introduction/", variant: "primary" },
	{ text: "GitHub", link: "https://github.com/lucasilverentand/canaveral", variant: "secondary" }
];
---

<div class="hero">
	<div class="hero-inner">
		<div class="hero-badge">
			<span class="badge-dot"></span>
			Now open source
		</div>

		<h1 id="_top" data-page-title set:html={title} />
		<p class="tagline" set:html={tagline} />

		<div class="actions">
			{actions.map(({ text, link, variant }) => (
				<a href={link} class={`action-btn ${variant}`} target={variant === 'secondary' ? '_blank' : undefined} rel={variant === 'secondary' ? 'noopener' : undefined}>
					{variant === 'secondary' && (
						<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
							<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
						</svg>
					)}
					{text}
					{variant === 'primary' && <span class="arrow">&rarr;</span>}
				</a>
			))}
		</div>

		<div class="install-command">
			<span class="install-prefix">$</span>
			<code>curl -fsSL https://get.canaveral.dev | sh</code>
			<button class="copy-btn" onclick="navigator.clipboard.writeText('curl -fsSL https://get.canaveral.dev | sh').then(() => this.classList.add('copied')).then(() => setTimeout(() => this.classList.remove('copied'), 2000))">
				<svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
					<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
				</svg>
				<svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<polyline points="20 6 9 17 4 12"></polyline>
				</svg>
			</button>
		</div>

		<div class="hero-pills">
			<span class="pill">Flutter</span>
			<span class="pill">Expo</span>
			<span class="pill">React Native</span>
			<span class="pill">Swift</span>
			<span class="pill">Android</span>
			<span class="pill">Tauri</span>
		</div>
	</div>
</div>

<style>
	.hero {
		position: relative;
		padding: 8rem 1.5rem 6rem;
		display: flex;
		align-items: center;
		justify-content: center;
		background: #09090b;
		overflow: hidden;
	}

	.hero::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image: radial-gradient(circle, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
		background-size: 24px 24px;
		mask-image: radial-gradient(ellipse at 50% 50%, black 30%, transparent 70%);
		-webkit-mask-image: radial-gradient(ellipse at 50% 50%, black 30%, transparent 70%);
	}

	.hero::after {
		content: '';
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 600px;
		height: 400px;
		background: radial-gradient(ellipse, rgba(249, 115, 22, 0.08) 0%, transparent 70%);
		pointer-events: none;
	}

	.hero-inner {
		position: relative;
		z-index: 1;
		max-width: 720px;
		text-align: center;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.375rem 0.875rem;
		margin-bottom: 2rem;
		background: rgba(249, 115, 22, 0.08);
		border: 1px solid rgba(249, 115, 22, 0.15);
		border-radius: 9999px;
		font-size: 0.8rem;
		font-weight: 500;
		color: #f97316;
		letter-spacing: 0.01em;
	}

	.badge-dot {
		width: 6px;
		height: 6px;
		background: #f97316;
		border-radius: 50%;
	}

	h1 {
		font-size: clamp(2.75rem, 6vw, 4.5rem);
		font-weight: 700;
		line-height: 1.05;
		margin: 0 0 1.5rem 0;
		color: #fafafa;
		letter-spacing: -0.03em;
	}

	.tagline {
		font-size: clamp(1.05rem, 1.8vw, 1.2rem);
		color: #a1a1aa;
		margin: 0 0 2.5rem 0;
		line-height: 1.7;
		max-width: 560px;
		margin-left: auto;
		margin-right: auto;
	}

	.actions {
		display: flex;
		justify-content: center;
		gap: 0.75rem;
		margin-bottom: 2rem;
	}

	.action-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		border-radius: 10px;
		font-weight: 500;
		font-size: 0.9rem;
		text-decoration: none;
		transition: all 0.15s ease;
	}

	.action-btn.primary {
		background: #f97316;
		color: white;
	}

	.action-btn.primary:hover {
		background: #ea580c;
	}

	.action-btn.secondary {
		background: rgba(255, 255, 255, 0.04);
		color: #fafafa;
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.action-btn.secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.16);
	}

	.action-btn .arrow {
		transition: transform 0.15s ease;
	}

	.action-btn:hover .arrow {
		transform: translateX(3px);
	}

	.install-command {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 10px;
		padding: 0.75rem 1rem;
		font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
		font-size: 0.8rem;
		margin-bottom: 2.5rem;
	}

	.install-prefix {
		color: #71717a;
		user-select: none;
	}

	.install-command code {
		color: #a1a1aa;
		background: none;
		padding: 0;
		border: none;
	}

	.copy-btn {
		background: none;
		border: none;
		color: #52525b;
		cursor: pointer;
		padding: 0.25rem;
		border-radius: 4px;
		transition: color 0.15s ease;
		display: flex;
		align-items: center;
	}

	.copy-btn:hover {
		color: #fafafa;
	}

	.copy-btn .check-icon { display: none; }
	.copy-btn.copied .copy-icon { display: none; }
	.copy-btn.copied .check-icon { display: block; color: #22c55e; }

	.hero-pills {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.pill {
		padding: 0.3rem 0.75rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 8px;
		font-size: 0.8rem;
		color: #71717a;
		transition: all 0.15s ease;
	}

	.pill:hover {
		color: #a1a1aa;
		border-color: rgba(255, 255, 255, 0.12);
	}

	@media (max-width: 640px) {
		.hero {
			padding: 6rem 1rem 4rem;
		}

		.actions {
			flex-direction: column;
			align-items: center;
		}

		.action-btn {
			width: 100%;
			max-width: 260px;
			justify-content: center;
		}
	}

	/* Light theme */
	:root[data-theme='light'] .hero {
		background: #fafafa;
	}

	:root[data-theme='light'] .hero::before {
		background-image: radial-gradient(circle, rgba(0, 0, 0, 0.04) 1px, transparent 1px);
	}

	:root[data-theme='light'] .hero::after {
		background: radial-gradient(ellipse, rgba(234, 88, 12, 0.06) 0%, transparent 70%);
	}

	:root[data-theme='light'] .hero-badge {
		background: rgba(234, 88, 12, 0.06);
		border-color: rgba(234, 88, 12, 0.12);
		color: #ea580c;
	}

	:root[data-theme='light'] .badge-dot { background: #ea580c; }

	:root[data-theme='light'] h1 { color: #09090b; }
	:root[data-theme='light'] .tagline { color: #52525b; }

	:root[data-theme='light'] .action-btn.primary {
		background: #ea580c;
	}
	:root[data-theme='light'] .action-btn.primary:hover {
		background: #c2410c;
	}

	:root[data-theme='light'] .action-btn.secondary {
		background: rgba(0, 0, 0, 0.02);
		border-color: rgba(0, 0, 0, 0.1);
		color: #09090b;
	}
	:root[data-theme='light'] .action-btn.secondary:hover {
		background: rgba(0, 0, 0, 0.04);
	}

	:root[data-theme='light'] .install-command {
		background: rgba(0, 0, 0, 0.02);
		border-color: rgba(0, 0, 0, 0.08);
	}
	:root[data-theme='light'] .install-prefix { color: #a1a1aa; }
	:root[data-theme='light'] .install-command code { color: #52525b; }

	:root[data-theme='light'] .pill {
		background: rgba(0, 0, 0, 0.02);
		border-color: rgba(0, 0, 0, 0.06);
		color: #a1a1aa;
	}
	:root[data-theme='light'] .pill:hover {
		color: #52525b;
		border-color: rgba(0, 0, 0, 0.12);
	}
</style>
