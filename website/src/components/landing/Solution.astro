---
// Solution Section — terminal demo with before/after
import SectionHeader from './shared/SectionHeader.astro';
import Terminal from './shared/Terminal.astro';
---

<section class="solution-section">
	<div class="container">
		<SectionHeader
			label="How it works"
			title="Build, test, sign, ship"
			description="Same commands work locally and in CI. Auto-detects your framework and applies the right pipeline."
		/>

		<div class="demo-grid">
			<div class="demo-block">
				<div class="demo-label">Build</div>
				<Terminal title="Terminal">
					<div class="line"><span class="prompt">$</span> <span class="command">canaveral build --platform ios</span></div>
					<div class="line"><span class="output">Detected Flutter project</span></div>
					<div class="line"><span class="output">Building iOS release...</span></div>
					<div class="line"><span class="success">MyApp.ipa (42.3 MB) in 2m 34s</span></div>
				</Terminal>
			</div>

			<div class="demo-block">
				<div class="demo-label">Ship</div>
				<Terminal title="Terminal">
					<div class="line"><span class="prompt">$</span> <span class="command">canaveral testflight upload build/ios/*.ipa</span></div>
					<div class="line"><span class="output">Uploading to App Store Connect...</span></div>
					<div class="line"><span class="output">Processing build...</span></div>
					<div class="line"><span class="success">Build 1.2.3 (42) submitted to TestFlight</span></div>
				</Terminal>
			</div>
		</div>

		<div class="benefits-row">
			<div class="benefit">
				<div class="benefit-title">Declarative config</div>
				<div class="benefit-desc">TOML instead of Ruby scripts. Version-controlled, team-readable.</div>
			</div>
			<div class="benefit">
				<div class="benefit-title">CI/CD-first</div>
				<div class="benefit-desc">Works identically locally and in your pipeline. Zero env differences.</div>
			</div>
			<div class="benefit">
				<div class="benefit-title">Built-in signing</div>
				<div class="benefit-desc">Certificates and profiles synced from encrypted git storage.</div>
			</div>
			<div class="benefit">
				<div class="benefit-title">Monorepo-aware</div>
				<div class="benefit-desc">Workspace detection, dependency graph, change-based test selection.</div>
			</div>
		</div>
	</div>
</section>

<style>
	.solution-section {
		position: relative;
		padding: 6rem 1.5rem;
		background: #09090b;
	}

	.solution-section::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image: radial-gradient(circle, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
		background-size: 24px 24px;
		mask-image: linear-gradient(to bottom, transparent, black 30%, black 70%, transparent);
		-webkit-mask-image: linear-gradient(to bottom, transparent, black 30%, black 70%, transparent);
	}

	.container {
		max-width: 900px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.demo-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
		margin-bottom: 3.5rem;
	}

	.demo-label {
		font-size: 0.75rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--c-text-muted);
		margin-bottom: 0.75rem;
	}

	.line {
		margin-bottom: 0.375rem;
		font-size: 0.8rem;
	}

	.benefits-row {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1px;
		background: var(--c-border);
		border: 1px solid var(--c-border);
		border-radius: 12px;
		overflow: hidden;
	}

	.benefit {
		padding: 1.5rem;
		background: #09090b;
	}

	.benefit-title {
		font-weight: 600;
		font-size: 0.9rem;
		color: var(--c-text-primary);
		margin-bottom: 0.5rem;
	}

	.benefit-desc {
		font-size: 0.8rem;
		color: var(--c-text-muted);
		line-height: 1.6;
	}

	@media (max-width: 768px) {
		.demo-grid { grid-template-columns: 1fr; }
		.benefits-row { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 480px) {
		.solution-section { padding: 4rem 1rem; }
		.benefits-row { grid-template-columns: 1fr; }
	}

	:root[data-theme='light'] .solution-section { background: #fafafa; }
	:root[data-theme='light'] .benefit { background: #fafafa; }
</style>
