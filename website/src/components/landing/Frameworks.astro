---
import SectionHeader from './shared/SectionHeader.astro';

const frameworks = [
	{ name: 'Flutter', platforms: ['iOS', 'Android', 'Web', 'Desktop'] },
	{ name: 'Expo', platforms: ['iOS', 'Android', 'Web'] },
	{ name: 'React Native', platforms: ['iOS', 'Android'] },
	{ name: 'Native iOS', platforms: ['iOS', 'iPadOS', 'macOS'] },
	{ name: 'Native Android', platforms: ['Android', 'Wear OS'] },
	{ name: 'Tauri', platforms: ['iOS', 'Android', 'Desktop'] },
];
---

<section class="frameworks-section">
	<div class="container">
		<SectionHeader
			label="Frameworks"
			title="Works with your stack"
			description="Auto-detects your framework and applies the optimal pipeline. Zero configuration."
		/>

		<div class="frameworks-grid">
			{frameworks.map((fw) => (
				<div class="fw-card">
					<div class="fw-name">{fw.name}</div>
					<div class="fw-platforms">
						{fw.platforms.map(p => (
							<span class="fw-platform">{p}</span>
						))}
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.frameworks-section {
		padding: 6rem 1.5rem;
		background: #09090b;
		border-top: 1px solid var(--c-border);
	}

	.container {
		max-width: 800px;
		margin: 0 auto;
	}

	.frameworks-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		background: var(--c-border);
		border: 1px solid var(--c-border);
		border-radius: 12px;
		overflow: hidden;
	}

	.fw-card {
		padding: 1.5rem;
		background: #09090b;
		transition: background 0.15s ease;
	}

	.fw-card:hover {
		background: rgba(255, 255, 255, 0.02);
	}

	.fw-name {
		font-weight: 600;
		font-size: 0.95rem;
		color: var(--c-text-primary);
		margin-bottom: 0.75rem;
	}

	.fw-platforms {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.fw-platform {
		padding: 0.2rem 0.5rem;
		background: var(--c-surface);
		border: 1px solid var(--c-border);
		border-radius: 6px;
		font-size: 0.7rem;
		color: var(--c-text-muted);
	}

	@media (max-width: 640px) {
		.frameworks-section { padding: 4rem 1rem; }
		.frameworks-grid { grid-template-columns: repeat(2, 1fr); }
	}

	:root[data-theme='light'] .frameworks-section { background: #fafafa; border-top-color: var(--c-border); }
	:root[data-theme='light'] .fw-card { background: #fafafa; }
	:root[data-theme='light'] .fw-card:hover { background: rgba(0, 0, 0, 0.01); }
</style>
