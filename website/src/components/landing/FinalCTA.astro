---
// Final CTA
---

<section class="cta-section">
	<div class="container">
		<h2 class="cta-title">Ready to simplify your releases?</h2>
		<p class="cta-desc">Get started in under a minute. Open source, MIT licensed.</p>

		<div class="cta-actions">
			<a href="/canaveral/getting-started/introduction/" class="cta-btn primary">
				Get started <span class="arrow">&rarr;</span>
			</a>
			<a href="https://github.com/lucasilverentand/canaveral" class="cta-btn secondary" target="_blank" rel="noopener">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
					<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
				</svg>
				Star on GitHub
			</a>
		</div>

		<div class="cta-install">
			<code>curl -fsSL https://get.canaveral.dev | sh</code>
		</div>
	</div>
</section>

<style>
	.cta-section {
		padding: 8rem 1.5rem;
		background: #09090b;
		border-top: 1px solid var(--c-border);
		text-align: center;
		position: relative;
	}

	.cta-section::before {
		content: '';
		position: absolute;
		bottom: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 600px;
		height: 300px;
		background: radial-gradient(ellipse, rgba(249, 115, 22, 0.06) 0%, transparent 70%);
		pointer-events: none;
	}

	.container {
		max-width: 560px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.cta-title {
		font-size: clamp(2rem, 4vw, 2.75rem);
		font-weight: 700;
		color: var(--c-text-primary);
		margin: 0 0 1rem 0;
		letter-spacing: -0.02em;
		line-height: 1.15;
	}

	.cta-desc {
		font-size: 1.05rem;
		color: var(--c-text-secondary);
		margin: 0 0 2.5rem 0;
		line-height: 1.6;
	}

	.cta-actions {
		display: flex;
		justify-content: center;
		gap: 0.75rem;
		margin-bottom: 2rem;
	}

	.cta-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		border-radius: 10px;
		font-weight: 500;
		font-size: 0.9rem;
		text-decoration: none;
		transition: all 0.15s ease;
	}

	.cta-btn.primary {
		background: #f97316;
		color: white;
	}

	.cta-btn.primary:hover {
		background: #ea580c;
	}

	.cta-btn.secondary {
		background: rgba(255, 255, 255, 0.04);
		color: #fafafa;
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.cta-btn.secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.16);
	}

	.cta-btn .arrow {
		transition: transform 0.15s ease;
	}

	.cta-btn:hover .arrow {
		transform: translateX(3px);
	}

	.cta-install code {
		font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
		font-size: 0.8rem;
		color: var(--c-text-muted);
		background: none;
		border: none;
		padding: 0;
	}

	@media (max-width: 480px) {
		.cta-section { padding: 5rem 1rem; }
		.cta-actions { flex-direction: column; align-items: center; }
		.cta-btn { width: 100%; max-width: 240px; justify-content: center; }
	}

	:root[data-theme='light'] .cta-section { background: #fafafa; border-top-color: var(--c-border); }
	:root[data-theme='light'] .cta-section::before {
		background: radial-gradient(ellipse, rgba(234, 88, 12, 0.04) 0%, transparent 70%);
	}
	:root[data-theme='light'] .cta-btn.primary { background: #ea580c; }
	:root[data-theme='light'] .cta-btn.primary:hover { background: #c2410c; }
	:root[data-theme='light'] .cta-btn.secondary {
		background: rgba(0, 0, 0, 0.02);
		border-color: rgba(0, 0, 0, 0.1);
		color: #09090b;
	}
</style>
