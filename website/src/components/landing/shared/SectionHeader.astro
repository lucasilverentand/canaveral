---
interface Props {
	label?: string;
	title: string;
	description?: string;
	align?: 'left' | 'center';
}

const { label, title, description, align = 'center' } = Astro.props;
---

<div class:list={['section-header', `align-${align}`]}>
	{label && <span class="section-label">{label}</span>}
	<h2 class="section-title" set:html={title} />
	{description && <p class="section-description" set:html={description} />}
</div>

<style>
	.section-header {
		margin-bottom: 3.5rem;
	}

	.align-center { text-align: center; }
	.align-left { text-align: left; }

	.section-label {
		display: inline-block;
		padding: 0.3rem 0.75rem;
		margin-bottom: 1.25rem;
		font-size: 0.75rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--c-accent);
		background: var(--c-accent-subtle);
		border: 1px solid var(--c-accent-border);
		border-radius: 9999px;
	}

	.section-title {
		font-size: clamp(2rem, 4vw, 2.75rem);
		font-weight: 700;
		line-height: 1.15;
		margin: 0 0 1rem 0;
		color: var(--c-text-primary);
		letter-spacing: -0.02em;
	}

	.section-description {
		font-size: clamp(1rem, 1.8vw, 1.1rem);
		color: var(--c-text-secondary);
		line-height: 1.7;
		max-width: 560px;
		margin: 0;
	}

	.align-center .section-description {
		margin-left: auto;
		margin-right: auto;
	}
</style>
