---
interface Props {
	title?: string;
}

const { title = 'Terminal' } = Astro.props;
---

<div class="terminal">
	<div class="terminal-header">
		<div class="terminal-dots">
			<span class="dot dot-red"></span>
			<span class="dot dot-yellow"></span>
			<span class="dot dot-green"></span>
		</div>
		<span class="terminal-title">{title}</span>
		<div class="terminal-spacer"></div>
	</div>
	<div class="terminal-body">
		<slot />
	</div>
</div>

<style>
	.terminal {
		border-radius: 12px;
		overflow: hidden;
		border: 1px solid var(--c-border);
		font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', 'Cascadia Code', monospace;
	}

	.terminal-header {
		display: flex;
		align-items: center;
		padding: 0.75rem 1rem;
		background: rgba(255, 255, 255, 0.02);
		border-bottom: 1px solid var(--c-border);
	}

	.terminal-dots {
		display: flex;
		gap: 6px;
	}

	.dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
	}

	.dot-red { background: #3f3f46; }
	.dot-yellow { background: #3f3f46; }
	.dot-green { background: #3f3f46; }

	.terminal:hover .dot-red { background: #ef4444; }
	.terminal:hover .dot-yellow { background: #eab308; }
	.terminal:hover .dot-green { background: #22c55e; }

	.terminal-title {
		flex: 1;
		text-align: center;
		font-size: 0.7rem;
		color: #52525b;
		font-family: 'Inter', -apple-system, sans-serif;
	}

	.terminal-spacer { width: 46px; }

	.terminal-body {
		padding: 1.25rem;
		font-size: 0.8rem;
		line-height: 1.8;
		color: #a1a1aa;
		background: rgba(0, 0, 0, 0.3);
	}

	.terminal-body :global(code) {
		background: none;
		padding: 0;
		border: none;
		font-size: inherit;
	}

	.terminal-body :global(.prompt) { color: #52525b; user-select: none; }
	.terminal-body :global(.command) { color: #fafafa; }
	.terminal-body :global(.output) { color: #71717a; }
	.terminal-body :global(.success) { color: #22c55e; }
	.terminal-body :global(.warning) { color: #eab308; }
	.terminal-body :global(.error) { color: #ef4444; }
	.terminal-body :global(.accent) { color: #f97316; }
	.terminal-body :global(.muted) { color: #52525b; }

	:root[data-theme='light'] .terminal-body {
		background: rgba(0, 0, 0, 0.02);
		color: #52525b;
	}
	:root[data-theme='light'] .terminal-body :global(.command) { color: #09090b; }
	:root[data-theme='light'] .terminal-body :global(.output) { color: #a1a1aa; }
	:root[data-theme='light'] .dot-red, :root[data-theme='light'] .dot-yellow, :root[data-theme='light'] .dot-green { background: #d4d4d8; }
	:root[data-theme='light'] .terminal:hover .dot-red { background: #ef4444; }
	:root[data-theme='light'] .terminal:hover .dot-yellow { background: #eab308; }
	:root[data-theme='light'] .terminal:hover .dot-green { background: #22c55e; }
</style>
