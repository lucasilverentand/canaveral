---
import SectionHeader from './shared/SectionHeader.astro';

const features = [
	{
		title: 'Universal builds',
		description: 'One command builds any app. Flutter, Expo, React Native, native iOS/Android, Tauri — same interface, auto-detected.',
	},
	{
		title: 'Smart test selection',
		description: 'Only run tests covering changed code. Uses the dependency graph and file-level change detection.',
	},
	{
		title: 'Version management',
		description: 'SemVer, CalVer, or build numbers from conventional commits. Monorepo-aware with independent or coordinated versioning.',
	},
	{
		title: 'Code signing',
		description: 'Match-style certificate sync from encrypted git repos. Team members get signing working in one command.',
	},
	{
		title: 'Store distribution',
		description: 'Publish to TestFlight, Google Play, App Store, npm, crates.io. Manage metadata, screenshots, and staged rollouts.',
	},
	{
		title: 'CI/CD integration',
		description: 'Generate thin CI configs that delegate to Canaveral. GitHub Actions, GitLab CI, Bitrise, CircleCI.',
	},
];
---

<section class="features-section">
	<div class="container">
		<SectionHeader
			label="Features"
			title="Everything you need to ship"
			description="From first build to production release, in a single toolchain."
		/>

		<div class="features-grid">
			{features.map((feature) => (
				<div class="feature-card">
					<h3 class="feature-title">{feature.title}</h3>
					<p class="feature-desc">{feature.description}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.features-section {
		position: relative;
		padding: 6rem 1.5rem;
		background: #09090b;
		border-top: 1px solid var(--c-border);
	}

	.container {
		max-width: 1000px;
		margin: 0 auto;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		background: var(--c-border);
		border: 1px solid var(--c-border);
		border-radius: 12px;
		overflow: hidden;
	}

	.feature-card {
		padding: 2rem;
		background: #09090b;
		transition: background 0.15s ease;
	}

	.feature-card:hover {
		background: rgba(255, 255, 255, 0.02);
	}

	.feature-title {
		font-size: 1rem;
		font-weight: 600;
		color: var(--c-text-primary);
		margin: 0 0 0.625rem 0;
	}

	.feature-desc {
		font-size: 0.85rem;
		color: var(--c-text-muted);
		line-height: 1.6;
		margin: 0;
	}

	@media (max-width: 768px) {
		.features-grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 480px) {
		.features-section { padding: 4rem 1rem; }
		.features-grid { grid-template-columns: 1fr; }
	}

	:root[data-theme='light'] .features-section { background: #fafafa; border-top-color: var(--c-border); }
	:root[data-theme='light'] .feature-card { background: #fafafa; }
	:root[data-theme='light'] .feature-card:hover { background: rgba(0, 0, 0, 0.01); }
</style>
