---
const innerRing = [
	'Fastlane',
	'Turborepo',
	'match',
	'semantic-release',
];

const outerRing = [
	'release-please',
	'Bitrise Steps',
	'goreleaser',
	'Tuist',
	'EAS Build',
	'Custom scripts',
];
---

<section class="replaces-section">
	<div class="replaces-container">
		<div class="replaces-header">
			<span class="replaces-label">Replaces</span>
			<h2 class="replaces-title">One tool, not ten</h2>
			<p class="replaces-desc">Canaveral consolidates your entire release toolchain into a single CLI.</p>
		</div>

		<div class="orbit-viewport">
			<div class="orbit-scene" id="orbit-scene">
				<!-- Ring tracks -->
				<div class="track track-inner"></div>
				<div class="track track-outer"></div>

				<!-- Dashed connectors (decorative) -->
				<div class="connector-ring connector-inner"></div>
				<div class="connector-ring connector-outer"></div>

				<!-- Center -->
				<div class="orbit-center">
					<div class="center-glow"></div>
					<span class="center-text">canaveral</span>
				</div>

				<!-- Inner ring (rotates clockwise) -->
				<div class="ring ring-inner" data-speed="40" data-items={JSON.stringify(innerRing)}>
					{innerRing.map((tool, i) => (
						<div class="node" data-index={i} data-total={innerRing.length}>
							<span class="pill">{tool}</span>
						</div>
					))}
				</div>

				<!-- Outer ring (rotates counter-clockwise) -->
				<div class="ring ring-outer" data-speed="55" data-items={JSON.stringify(outerRing)}>
					{outerRing.map((tool, i) => (
						<div class="node" data-index={i} data-total={outerRing.length}>
							<span class="pill">{tool}</span>
						</div>
					))}
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.replaces-section {
		position: relative;
		padding: 6rem 1.5rem 4rem;
		background: #09090b;
		overflow: hidden;
	}

	.replaces-container {
		max-width: 1000px;
		margin: 0 auto;
	}

	.replaces-header {
		text-align: center;
		margin-bottom: 2rem;
	}

	.replaces-label {
		display: inline-block;
		padding: 0.3rem 0.75rem;
		margin-bottom: 1.25rem;
		font-size: 0.75rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--c-accent);
		background: var(--c-accent-subtle);
		border: 1px solid var(--c-accent-border);
		border-radius: 9999px;
	}

	.replaces-title {
		font-size: clamp(2rem, 4vw, 2.75rem);
		font-weight: 700;
		line-height: 1.15;
		margin: 0 0 1rem 0;
		color: var(--c-text-primary);
		letter-spacing: -0.02em;
	}

	.replaces-desc {
		font-size: clamp(1rem, 1.8vw, 1.1rem);
		color: var(--c-text-secondary);
		line-height: 1.7;
		max-width: 480px;
		margin: 0 auto;
	}

	/* Orbit viewport */
	.orbit-viewport {
		width: 100%;
		max-width: 620px;
		margin: 0 auto;
	}

	.orbit-scene {
		position: relative;
		width: 100%;
		padding-bottom: 100%; /* 1:1 aspect ratio */
	}

	/* Static ring tracks */
	.track {
		position: absolute;
		border-radius: 50%;
		border: 1px solid rgba(255, 255, 255, 0.04);
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		pointer-events: none;
	}

	.track-inner {
		width: 52%;
		height: 52%;
	}

	.track-outer {
		width: 88%;
		height: 88%;
	}

	/* Dashed connector rings */
	.connector-ring {
		position: absolute;
		border-radius: 50%;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		pointer-events: none;
		border: 1px dashed rgba(255, 255, 255, 0.03);
	}

	.connector-inner { width: 36%; height: 36%; }
	.connector-outer { width: 70%; height: 70%; }

	/* Center */
	.orbit-center {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		z-index: 10;
	}

	.center-glow {
		position: absolute;
		inset: -30px;
		background: radial-gradient(circle, rgba(249, 115, 22, 0.1) 0%, transparent 70%);
		border-radius: 50%;
		pointer-events: none;
	}

	.center-text {
		position: relative;
		display: block;
		font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
		font-size: 1rem;
		font-weight: 700;
		color: var(--c-accent);
		background: #09090b;
		border: 1px solid rgba(249, 115, 22, 0.25);
		padding: 0.75rem 1.5rem;
		border-radius: 12px;
		white-space: nowrap;
	}

	/* Rotating ring wrappers */
	.ring {
		position: absolute;
		border-radius: 50%;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
	}

	.ring-inner {
		width: 52%;
		height: 52%;
		animation: spin 40s linear infinite;
	}

	.ring-outer {
		width: 88%;
		height: 88%;
		animation: spin 55s linear infinite reverse;
	}

	@keyframes spin {
		to { transform: translate(-50%, -50%) rotate(360deg); }
	}

	/* Nodes positioned by JS */
	.node {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%); /* JS overrides this */
	}

	/* Counter-rotate pills to stay horizontal */
	.ring-inner .pill {
		animation: counter-spin 40s linear infinite;
	}

	.ring-outer .pill {
		animation: counter-spin 55s linear infinite reverse;
	}

	@keyframes counter-spin {
		to { transform: rotate(-360deg); }
	}

	.pill {
		display: inline-block;
		padding: 0.4rem 0.875rem;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 9999px;
		font-size: 0.8rem;
		font-weight: 500;
		color: #a1a1aa;
		white-space: nowrap;
		cursor: default;
		transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
		will-change: transform;
	}

	.pill:hover {
		color: #fafafa;
		border-color: rgba(255, 255, 255, 0.16);
		background: rgba(255, 255, 255, 0.07);
	}

	/* Reduced motion */
	@media (prefers-reduced-motion: reduce) {
		.ring-inner,
		.ring-outer { animation: none !important; }
		.ring-inner .pill,
		.ring-outer .pill { animation: none !important; }
	}

	/* Responsive */
	@media (max-width: 640px) {
		.orbit-viewport { max-width: 380px; }
		.pill { font-size: 0.7rem; padding: 0.3rem 0.625rem; }
		.center-text { font-size: 0.85rem; padding: 0.625rem 1.125rem; }
	}

	@media (max-width: 400px) {
		.orbit-viewport { max-width: 320px; }
		.pill { font-size: 0.65rem; padding: 0.25rem 0.5rem; }
	}

	/* Light theme */
	:root[data-theme='light'] .replaces-section { background: #fafafa; }
	:root[data-theme='light'] .track { border-color: rgba(0, 0, 0, 0.05); }
	:root[data-theme='light'] .connector-ring { border-color: rgba(0, 0, 0, 0.03); }
	:root[data-theme='light'] .center-text {
		background: #fafafa;
		border-color: rgba(234, 88, 12, 0.25);
	}
	:root[data-theme='light'] .center-glow {
		background: radial-gradient(circle, rgba(234, 88, 12, 0.08) 0%, transparent 70%);
	}
	:root[data-theme='light'] .pill {
		background: rgba(0, 0, 0, 0.02);
		border-color: rgba(0, 0, 0, 0.08);
		color: #71717a;
	}
	:root[data-theme='light'] .pill:hover {
		color: #09090b;
		border-color: rgba(0, 0, 0, 0.16);
		background: rgba(0, 0, 0, 0.04);
	}
</style>

<script>
	function positionNodes() {
		const rings = document.querySelectorAll<HTMLElement>('.ring');
		rings.forEach(ring => {
			const nodes = ring.querySelectorAll<HTMLElement>('.node');
			const radius = ring.offsetWidth / 2;
			const count = nodes.length;

			nodes.forEach((node, i) => {
				// Distribute evenly, start from top (-90deg)
				const angle = (i / count) * Math.PI * 2 - Math.PI / 2;
				const x = Math.cos(angle) * radius;
				const y = Math.sin(angle) * radius;
				node.style.transform = `translate(calc(-50% + ${x}px), calc(-50% + ${y}px))`;
			});
		});
	}

	// Run on load and resize
	positionNodes();
	window.addEventListener('resize', positionNodes);

	// Re-run after fonts load (can shift pill sizes)
	document.fonts?.ready.then(positionNodes);
</script>
