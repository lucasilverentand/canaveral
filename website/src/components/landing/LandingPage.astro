---
import PainPoints from './PainPoints.astro';
import Solution from './Solution.astro';
import Features from './Features.astro';
import Frameworks from './Frameworks.astro';
import Comparison from './Comparison.astro';
import QuickStart from './QuickStart.astro';
import FinalCTA from './FinalCTA.astro';
---

<div class="landing-page">
	<PainPoints />
	<Solution />
	<Features />
	<Frameworks />
	<Comparison />
	<QuickStart />
	<FinalCTA />
</div>

<style is:global>
	.landing-page {
		width: 100%;
	}

	@media (prefers-reduced-motion: reduce) {
		* {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
		}
	}
</style>
