---
import SectionHeader from './shared/SectionHeader.astro';
import Terminal from './shared/Terminal.astro';
---

<section class="quickstart-section">
	<div class="container">
		<SectionHeader
			label="Quick start"
			title="Four commands to production"
		/>

		<div class="steps">
			<div class="step">
				<div class="step-num">1</div>
				<div class="step-content">
					<div class="step-label">Install</div>
					<code class="step-cmd">curl -fsSL https://get.canaveral.dev | sh</code>
				</div>
			</div>
			<div class="step">
				<div class="step-num">2</div>
				<div class="step-content">
					<div class="step-label">Initialize</div>
					<code class="step-cmd">canaveral init</code>
				</div>
			</div>
			<div class="step">
				<div class="step-num">3</div>
				<div class="step-content">
					<div class="step-label">Build</div>
					<code class="step-cmd">canaveral build --platform ios</code>
				</div>
			</div>
			<div class="step">
				<div class="step-num">4</div>
				<div class="step-content">
					<div class="step-label">Ship</div>
					<code class="step-cmd">canaveral testflight upload build/ios/*.ipa</code>
				</div>
			</div>
		</div>

		<div class="ci-block">
			<div class="ci-label">Same commands in CI</div>
			<Terminal title=".github/workflows/release.yml">
				<pre><code><span class="accent">- name:</span> <span class="command">Build and ship</span>
  <span class="accent">run:</span> |
    curl -fsSL https://get.canaveral.dev | sh
    canaveral build --platform ios
    canaveral testflight upload build/ios/*.ipa
  <span class="accent">env:</span>
    <span class="accent">MATCH_PASSWORD:</span> <span class="muted">${"${{ secrets.MATCH_PASSWORD }}"}</span>
    <span class="accent">APP_STORE_CONNECT_API_KEY_ID:</span> <span class="muted">${"${{ secrets.ASC_KEY_ID }}"}</span></code></pre>
			</Terminal>
		</div>
	</div>
</section>

<style>
	.quickstart-section {
		padding: 6rem 1.5rem;
		background: #09090b;
		border-top: 1px solid var(--c-border);
	}

	.container {
		max-width: 640px;
		margin: 0 auto;
	}

	.steps {
		display: flex;
		flex-direction: column;
		gap: 0;
		border: 1px solid var(--c-border);
		border-radius: 12px;
		overflow: hidden;
		margin-bottom: 3rem;
	}

	.step {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		padding: 1.25rem 1.5rem;
		border-bottom: 1px solid var(--c-border);
		transition: background 0.15s ease;
	}

	.step:last-child { border-bottom: none; }

	.step:hover { background: rgba(255, 255, 255, 0.02); }

	.step-num {
		width: 28px;
		height: 28px;
		border-radius: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--c-accent);
		background: var(--c-accent-subtle);
		border: 1px solid var(--c-accent-border);
		flex-shrink: 0;
	}

	.step-content {
		flex: 1;
		min-width: 0;
	}

	.step-label {
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--c-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 0.25rem;
	}

	.step-cmd {
		font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
		font-size: 0.8rem;
		color: var(--c-text-secondary);
		background: none;
		padding: 0;
		border: none;
	}

	.ci-block {
		/* empty spacing handled by margin */
	}

	.ci-label {
		font-size: 0.75rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--c-text-muted);
		margin-bottom: 0.75rem;
	}

	.ci-block pre {
		margin: 0;
		font-size: 0.75rem;
		line-height: 1.7;
	}

	@media (max-width: 480px) {
		.quickstart-section { padding: 4rem 1rem; }
		.step { padding: 1rem; gap: 1rem; }
	}

	:root[data-theme='light'] .quickstart-section { background: #fafafa; border-top-color: var(--c-border); }
	:root[data-theme='light'] .step:hover { background: rgba(0, 0, 0, 0.01); }
</style>
