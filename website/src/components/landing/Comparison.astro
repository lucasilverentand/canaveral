---
import SectionHeader from './shared/SectionHeader.astro';
import Terminal from './shared/Terminal.astro';
---

<section class="comparison-section">
	<div class="container">
		<SectionHeader
			label="Before & after"
			title="Less config, more shipping"
			description="Replace Ruby DSLs and framework-specific scripts with declarative TOML."
		/>

		<div class="code-comparison">
			<div class="code-block">
				<div class="code-label before">Before: Fastfile</div>
				<Terminal title="Fastfile">
					<pre><code><span class="muted"># 50+ lines of Ruby for a basic iOS build</span>
<span class="command">lane</span> <span class="accent">:beta</span> <span class="command">do</span>
  match(
    <span class="accent">type:</span> <span class="success">"appstore"</span>,
    <span class="accent">readonly:</span> <span class="warning">true</span>
  )
  gym(
    <span class="accent">scheme:</span> <span class="success">"MyApp"</span>,
    <span class="accent">export_method:</span> <span class="success">"app-store"</span>,
    <span class="accent">output_directory:</span> <span class="success">"./build"</span>
  )
  pilot(
    <span class="accent">skip_waiting_for_build:</span> <span class="warning">true</span>
  )
<span class="command">end</span></code></pre>
				</Terminal>
			</div>

			<div class="code-block">
				<div class="code-label after">After: canaveral.toml</div>
				<Terminal title="canaveral.toml">
					<pre><code><span class="muted"># Clean, declarative config</span>
<span class="accent">[project]</span>
<span class="command">name</span> = <span class="success">"MyApp"</span>

<span class="accent">[signing]</span>
<span class="command">enabled</span> = <span class="warning">true</span>
<span class="command">provider</span> = <span class="success">"macos"</span>

<span class="accent">[signing.match]</span>
<span class="command">storage</span> = <span class="success">"git"</span>
<span class="command">git_url</span> = <span class="success">"git@github.com:org/certs"</span></code></pre>
				</Terminal>
			</div>
		</div>

		<div class="migration-cta">
			<a href="/canaveral/migration/from-fastlane/" class="migration-link">
				Read the Fastlane migration guide <span>&rarr;</span>
			</a>
		</div>
	</div>
</section>

<style>
	.comparison-section {
		padding: 6rem 1.5rem;
		background: #09090b;
		border-top: 1px solid var(--c-border);
	}

	.container {
		max-width: 900px;
		margin: 0 auto;
	}

	.code-comparison {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.code-label {
		display: inline-block;
		padding: 0.25rem 0.625rem;
		border-radius: 6px;
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.75rem;
	}

	.code-label.before {
		background: rgba(239, 68, 68, 0.08);
		color: #ef4444;
		border: 1px solid rgba(239, 68, 68, 0.15);
	}

	.code-label.after {
		background: rgba(34, 197, 94, 0.08);
		color: #22c55e;
		border: 1px solid rgba(34, 197, 94, 0.15);
	}

	.code-block pre {
		margin: 0;
		font-size: 0.75rem;
		line-height: 1.7;
	}

	.migration-cta {
		text-align: center;
	}

	.migration-link {
		color: var(--c-text-muted);
		text-decoration: none;
		font-size: 0.875rem;
		transition: color 0.15s ease;
	}

	.migration-link:hover {
		color: var(--c-accent);
	}

	@media (max-width: 768px) {
		.code-comparison { grid-template-columns: 1fr; }
	}

	@media (max-width: 480px) {
		.comparison-section { padding: 4rem 1rem; }
	}

	:root[data-theme='light'] .comparison-section { background: #fafafa; border-top-color: var(--c-border); }
</style>
