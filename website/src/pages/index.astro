---
import Hero from '../components/Hero.astro';
import LandingPage from '../components/landing/LandingPage.astro';
---

<!DOCTYPE html>
<html lang="en" dir="ltr" data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Canaveral — Ship software, not scripts</title>
		<meta name="description" content="A single CLI that builds, tests, signs, and publishes across every framework. Replace your patchwork of fastlane, shell scripts, and CI hacks." />

		<link rel="icon" type="image/png" href="/canaveral/favicon.png" />

		<meta property="og:title" content="Canaveral — Ship software, not scripts" />
		<meta property="og:description" content="A single CLI that builds, tests, signs, and publishes across every framework." />
		<meta property="og:image" content="https://lucasilverentand.github.io/canaveral/og-image.png" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="theme-color" content="#09090b" />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

		<style>
			*, *::before, *::after {
				box-sizing: border-box;
			}

			html, body {
				margin: 0;
				padding: 0;
				font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
				background: #09090b;
				color: #fafafa;
				overflow-x: hidden;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			/* Header */
			.site-header {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				z-index: 100;
				background: transparent;
				backdrop-filter: none;
				-webkit-backdrop-filter: none;
				border-bottom: 1px solid transparent;
				transition: background 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease;
			}

			.site-header.scrolled {
				background: rgba(9, 9, 11, 0.7);
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				border-bottom-color: rgba(255, 255, 255, 0.06);
			}

			.header-content {
				max-width: 1200px;
				margin: 0 auto;
				padding: 0.875rem 1.5rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}

			.logo-link {
				display: flex;
				align-items: center;
				gap: 0.625rem;
				text-decoration: none;
				font-weight: 600;
				font-size: 1rem;
				color: #fafafa;
				letter-spacing: -0.01em;
			}

			.logo-image {
				width: 24px;
				height: 24px;
			}

			.nav-links {
				display: flex;
				align-items: center;
				gap: 1.75rem;
			}

			.nav-link {
				color: #71717a;
				text-decoration: none;
				font-size: 0.875rem;
				font-weight: 450;
				transition: color 0.15s ease;
			}

			.nav-link:hover {
				color: #fafafa;
			}

			.github-link {
				display: flex;
				align-items: center;
				gap: 0.375rem;
			}

			/* Footer */
			.site-footer {
				background: #09090b;
				border-top: 1px solid rgba(255, 255, 255, 0.06);
				padding: 3rem 1.5rem 2rem;
			}

			.footer-content {
				max-width: 1200px;
				margin: 0 auto;
			}

			.footer-main {
				display: flex;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 3rem;
				margin-bottom: 3rem;
			}

			.footer-section {
				flex: 1;
				min-width: 160px;
			}

			.footer-title {
				font-weight: 500;
				font-size: 0.8rem;
				color: #fafafa;
				margin-bottom: 1rem;
				letter-spacing: 0.02em;
				text-transform: uppercase;
			}

			.footer-links {
				display: flex;
				flex-direction: column;
				gap: 0.625rem;
			}

			.footer-link {
				color: #71717a;
				text-decoration: none;
				font-size: 0.875rem;
				transition: color 0.15s ease;
			}

			.footer-link:hover {
				color: #fafafa;
			}

			.footer-bottom {
				padding-top: 2rem;
				border-top: 1px solid rgba(255, 255, 255, 0.06);
				text-align: center;
				color: #3f3f46;
				font-size: 0.8rem;
			}

			/* Light theme */
			:root[data-theme='light'] body {
				background: #fafafa;
				color: #09090b;
			}

			:root[data-theme='light'] .site-header.scrolled {
				background: rgba(250, 250, 250, 0.7);
				border-bottom-color: rgba(0, 0, 0, 0.06);
			}

			:root[data-theme='light'] .logo-link { color: #09090b; }
			:root[data-theme='light'] .nav-link { color: #a1a1aa; }
			:root[data-theme='light'] .nav-link:hover { color: #09090b; }

			:root[data-theme='light'] .site-footer {
				background: #fafafa;
				border-top-color: rgba(0, 0, 0, 0.06);
			}

			:root[data-theme='light'] .footer-title { color: #09090b; }
			:root[data-theme='light'] .footer-link { color: #a1a1aa; }
			:root[data-theme='light'] .footer-link:hover { color: #09090b; }
			:root[data-theme='light'] .footer-bottom { color: #d4d4d8; border-top-color: rgba(0, 0, 0, 0.06); }

			@media (max-width: 640px) {
				.nav-links { gap: 1rem; }
				.footer-main { flex-direction: column; gap: 2rem; }
			}
		</style>
	</head>
	<body>
		<header class="site-header">
			<div class="header-content">
				<a href="/canaveral/" class="logo-link">
					<img src="/canaveral/favicon.png" alt="" class="logo-image" />
					Canaveral
				</a>
				<nav class="nav-links">
					<a href="/canaveral/getting-started/introduction/" class="nav-link">Docs</a>
					<a href="https://github.com/lucasilverentand/canaveral" class="nav-link github-link" target="_blank" rel="noopener">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
							<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
						</svg>
						GitHub
					</a>
				</nav>
			</div>
		</header>

		<main>
			<Hero />
			<LandingPage />
		</main>

		<footer class="site-footer">
			<div class="footer-content">
				<div class="footer-main">
					<div class="footer-section">
						<div class="footer-title">Product</div>
						<div class="footer-links">
							<a href="/canaveral/getting-started/introduction/" class="footer-link">Introduction</a>
							<a href="/canaveral/getting-started/installation/" class="footer-link">Installation</a>
							<a href="/canaveral/reference/changelog/" class="footer-link">Changelog</a>
						</div>
					</div>
					<div class="footer-section">
						<div class="footer-title">Docs</div>
						<div class="footer-links">
							<a href="/canaveral/frameworks/overview/" class="footer-link">Frameworks</a>
							<a href="/canaveral/commands/build/" class="footer-link">Build & Test</a>
							<a href="/canaveral/signing/overview/" class="footer-link">Code Signing</a>
						</div>
					</div>
					<div class="footer-section">
						<div class="footer-title">Community</div>
						<div class="footer-links">
							<a href="https://github.com/lucasilverentand/canaveral" class="footer-link" target="_blank" rel="noopener">GitHub</a>
							<a href="https://github.com/lucasilverentand/canaveral/issues" class="footer-link" target="_blank" rel="noopener">Issues</a>
							<a href="https://github.com/lucasilverentand/canaveral/discussions" class="footer-link" target="_blank" rel="noopener">Discussions</a>
						</div>
					</div>
				</div>
				<div class="footer-bottom">
					Canaveral is open source under the MIT License
				</div>
			</div>
		</footer>

		<script is:inline>
			const theme = localStorage.getItem('starlight-theme') || 'dark';
			document.documentElement.setAttribute('data-theme', theme);

			const header = document.querySelector('.site-header');
			function onScroll() {
				header.classList.toggle('scrolled', window.scrollY > 20);
			}
			onScroll();
			window.addEventListener('scroll', onScroll, { passive: true });
		</script>
	</body>
</html>
